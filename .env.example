# Salin file ini ke .env.local dan sesuaikan nilainya.
# Jangan commit file .env.local ke git.

# Setel ke 'true' untuk menjalankan build statis export (next export).
EXPORT=

# Setel ke 'true' untuk mengaktifkan bundle analyzer saat build.
ANALYZE=

# Node environment (development | production)
NODE_ENV=development
